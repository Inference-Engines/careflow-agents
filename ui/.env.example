# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ── Agent Proxy (local dev) ──────────────────────────────────────────────────
# VITE_AGENT_BASE_URL: URL of the FastAPI proxy server (ui/server.py).
# The Vite dev server proxies /api/* to this address to avoid CORS issues.
VITE_AGENT_BASE_URL="http://localhost:8001"

# ADK_BASE_URL: URL of the running `adk web` ADK dev server.
# The FastAPI proxy (server.py) forwards agent calls here.
ADK_BASE_URL="http://localhost:8000"

# APP_NAME: ADK application name (must match the directory name ADK discovers).
APP_NAME="careflow"
